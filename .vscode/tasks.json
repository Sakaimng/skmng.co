{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev",
      "type": "npm",
      "script": "dev",
      "problemMatcher": {
        "owner": "typescript",
        "pattern": {
          "regexp": "^(.*)$",
          "message": 1
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready in|✓ Ready|started server"
        }
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "dev:fast",
      "type": "npm",
      "script": "dev:fast",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "deploy",
      "type": "shell",
      "command": "npm run deploy -- \"${input:deployTitle}\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    },
    {
      "label": "deploy:preview",
      "type": "shell",
      "command": "npm run deploy:preview -- \"${input:deployTitle}\"",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      }
    }
  ],
  "inputs": [
    {
      "id": "deployTitle",
      "type": "promptString",
      "description": "Deployment title (shown in terminal + Vercel)",
      "default": "Motion polish: archive landing, home chrome sync, nav lock, hard refresh outro"
    }
  ]
}
